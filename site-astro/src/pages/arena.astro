---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import site from "../data/site";

// Honest empty state: nothing is measured yet, so nothing on this page may
// read as a result. The central message is the first line of the hero —
// not fine print — and stays that way until a real run lands here.
const title = "Arena";
const description =
  "The arena is empty — no runs have been published yet. See what a run will measure, the first target device, and how to follow the build.";
const intro = [
  "The arena is empty. No runs have been published yet.",
  "This page describes the shape of what will land here: what a run is, what it will measure, and the first device it will measure it on. None of it is a result — it is the method, published before any number exists.",
];

// A run, defined before one exists. This is the unit the arena publishes:
// one device, one ordered pipeline, measured together — never a model
// benchmarked alone.
const runDefinition =
  "A run pairs one specific Jetson device with one setup — a single model, a mixture of models, or an ordered pipeline, under a pinned config — and measures that pairing as a single system, not as isolated parts. Every run will ship with the Docker recipe that reproduces it: the exact containers, models, and flags. Own the device, rerun the arena.";

// The three axes every published run will carry. Each names what WILL be
// measured — never a result, never a number.
const axes = [
  {
    name: "Latency",
    sub: "End to end, and per stage",
    copy: "The wall-clock story of one pass through the pipeline, and where inside it the time goes. Every run will carry the full breakdown, not a single headline figure.",
  },
  {
    name: "Memory signature",
    sub: "On unified memory",
    copy: "CPU and GPU share one pool on a Jetson, so the setup's whole footprint is what matters. Runs will record what each stage holds resident, and what remains for everything else on the board.",
  },
  {
    name: "Quality",
    sub: "Honest, per stage",
    copy: "A pipeline that answers fast but gets a stage wrong has not won anything. Each stage will be scored against its own task, and every trade-off made to fit the device will be stated with the run.",
  },
] as const;

// The canonical first target — named before anything is measured. Kept
// consistent with the homepage's phrasing.
const target = {
  device: "Jetson Thor",
  pipeline: "realtime voice loop",
  stages: [
    { abbr: "VAD", name: "voice activity detection" },
    { abbr: "STT", name: "speech to text" },
    { abbr: "LLM", name: "language model" },
    { abbr: "TTS", name: "text to speech" },
  ],
} as const;

const links = [
  {
    href: "https://github.com/agentculture/jetson-arena",
    label: "Source",
    copy: "The repository: the CLI, this site, and the recipes as they land.",
  },
  {
    href: "https://github.com/agentculture/jetson-arena/issues/1",
    label: "The build brief",
    copy: "The roadmap for what gets built before the first run ships.",
  },
] as const;
---

<Layout title={`${title} — ${site.name}`} description={description}>
  <PageHero title={title} intro={intro} />

  <section class="section" aria-labelledby="run-title">
    <div class="container prose">
      <span class="eyebrow" data-reveal>What a run is</span>
      <h2 id="run-title" data-reveal>One device, one setup, measured whole</h2>
      <p data-reveal>{runDefinition}</p>
    </div>
  </section>

  <section class="section axes" aria-labelledby="axes-title">
    <div class="container">
      <span class="eyebrow" data-reveal>Measured on three axes</span>
      <h2 id="axes-title" data-reveal>What every run will carry</h2>
      <ul class="axis-grid">
        {
          axes.map(({ name, sub, copy }, i) => (
            <li data-reveal style={`--reveal-delay: ${i * 0.12}s`}>
              <div class="card axis">
                <h3>{name}</h3>
                <p class="axis-sub">{sub}</p>
                <p class="muted">{copy}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section target" aria-labelledby="target-title">
    <div class="container">
      <span class="eyebrow" data-reveal>The first target</span>
      <h2 id="target-title" data-reveal>{target.device}</h2>
      <p class="lede" data-reveal style="--reveal-delay: 0.1s">
        A {target.pipeline}, running whole on one board: speak, and hear the
        reply. It is the first setup the arena will publish a run for.
      </p>
      <ol class="pipeline" aria-label="Pipeline stages, in order">
        {
          target.stages.map(({ abbr, name }, i) => (
            <li data-reveal style={`--reveal-delay: ${(0.12 + i * 0.1).toFixed(2)}s`}>
              <span class="node" aria-hidden="true" />
              <span class="abbr">{abbr}</span>
              <span class="stage muted">{name}</span>
            </li>
          ))
        }
      </ol>
      <p class="muted prose" data-reveal>
        Four stages contending for one pool of unified memory, in a loop a
        person can feel. None of it is measured yet — this is only where the
        result will go once it is. Next in line: Jetson AGX Orin on JetPack
        7.2, then Jetson Orin Nano Super 8GB.
      </p>
    </div>
  </section>

  <section class="section links" aria-labelledby="links-title">
    <div class="container">
      <span class="eyebrow" data-reveal>Follow along</span>
      <h2 id="links-title" data-reveal>Watch it get built</h2>
      <ul class="link-grid">
        {
          links.map(({ href, label, copy }, i) => (
            <li data-reveal style={`--reveal-delay: ${i * 0.12}s`}>
              <a class="card link-card" href={href}>
                <h3>{label}</h3>
                <p class="muted">{copy}</p>
                <span class="go" aria-hidden="true">
                  →
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>

<style>
  /* Reuses the homepage's pipeline-as-thread vocabulary and axis-card grid
     verbatim (same tokens, same rhythm) — Astro scopes <style> per file, so
     the rules are repeated here rather than shared, but nothing about the
     palette or motion is new. */

  .axes {
    padding-top: 0;
  }

  .axis-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15.5rem, 1fr));
    gap: 1.4rem;
    margin-top: 2.2rem;
  }

  /* grid's default stretch fills each cell without an explicit percentage */
  .axis-grid li {
    display: grid;
  }

  .axis h3 {
    font-size: 1.45rem;
    margin-bottom: 0.15em;
  }

  .axis-sub {
    font-size: 0.78rem;
    font-weight: 640;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .axis p:last-child {
    font-size: 0.97rem;
    line-height: 1.6;
  }

  .target {
    padding-top: 0;
  }

  .pipeline {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    row-gap: 1rem;
    margin: 2rem 0 1.8rem;
  }

  .pipeline li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .pipeline li:not(:last-child)::after {
    content: "";
    width: clamp(1.4rem, 4vw, 3.2rem);
    height: 1px;
    background: var(--mesh-thread);
    margin-inline: 1rem;
  }

  .pipeline .node {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--mesh-node);
    flex: none;
  }

  .pipeline .abbr {
    font-family: var(--font-mono);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--ink);
  }

  .pipeline .stage {
    font-size: 0.9rem;
  }

  .links {
    padding-top: 0;
  }

  .link-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15.5rem, 1fr));
    gap: 1.4rem;
    margin-top: 2.2rem;
  }

  /* grid's default stretch fills each cell without an explicit percentage */
  .link-grid li {
    display: grid;
  }

  .link-card {
    position: relative;
    padding-bottom: 3rem;
  }

  .link-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.3em;
  }

  .link-card p {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .link-card .go {
    position: absolute;
    left: 2rem;
    bottom: 1.5rem;
    color: var(--accent);
    font-size: 1.1rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-card .go {
      transition: transform 0.35s var(--ease-out);
    }

    .link-card:hover .go {
      transform: translateX(6px);
    }
  }
</style>
